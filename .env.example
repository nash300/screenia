# Screenia environment template
# Copy to .env.local for local development. Never commit real secrets.

# App URLs
NEXT_PUBLIC_APP_URL=https://screenia.se
NEXT_PUBLIC_EMAIL_ASSET_BASE_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_replace-with-stripe-test-secret-key
STRIPE_WEBHOOK_SECRET=whsec_replace-with-stripe-webhook-secret
STRIPE_AUTOMATIC_TAX_ENABLED=true

# Resend transactional email
RESEND_API_KEY=re_replace-with-send-restricted-resend-key
RESEND_FROM_EMAIL=Screenia <service@screenia.se>
RESEND_NEWSLETTER_FROM_EMAIL=Screenia <info@screenia.se>
RESEND_WEBHOOK_SECRET=whsec_replace-with-resend-webhook-secret

# Public company identity
NEXT_PUBLIC_COMPANY_LEGAL_NAME=Screenia
NEXT_PUBLIC_COMPANY_EMAIL=service@screenia.se
# Set these only when the Swedish business identity is confirmed.
NEXT_PUBLIC_COMPANY_ORG_NUMBER=
NEXT_PUBLIC_COMPANY_ADDRESS=

# Optional auth features
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# Live-payment gates
# Keep false until each item has real business/legal/technical proof.
SCREENIA_LIVE_PAYMENTS_ENABLED=false
SCREENIA_BUSINESS_REGISTRATION_CONFIRMED=false
SCREENIA_VERCEL_PRO_CONFIRMED=false
SCREENIA_VAT_DECISION_CONFIRMED=false
SCREENIA_LEGAL_REVIEW_CONFIRMED=false
SCREENIA_LIVE_WEBHOOK_VERIFIED=false
SCREENIA_SUPABASE_AUTH_EMAIL_VERIFIED=false
