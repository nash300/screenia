{
  "name": "screenia",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "text:check": "node scripts/check-text-quality.mjs",
    "style:check": "node scripts/check-style-boundaries.mjs",
    "billing:check": "node scripts/check-billing-invariants.mjs",
    "pricing:sync-components:test": "node scripts/sync-additional-setup-price.mjs",
    "pricing:verify-services": "node scripts/verify-pricing-services.mjs",
    "legal:sync": "node --env-file=.env.local scripts/sync-legal-documents.mjs",
    "admin-framework:check": "node scripts/check-admin-framework.mjs",
    "stripe:replay-dispute": "node scripts/replay-stripe-dispute-event.mjs",
    "stripe:replay-refund": "node scripts/replay-stripe-refund-event.mjs",
    "qa:customers:seed": "node --env-file=.env.local scripts/qa-customers.mjs seed --confirm-screenia-qa",
    "qa:customers:verify": "node --env-file=.env.local scripts/qa-customers.mjs verify",
    "qa:customers:clean": "node --env-file=.env.local scripts/qa-customers.mjs clean --confirm-screenia-qa",
    "release:check": "npm run lint && npm run text:check && npm run style:check && npm run billing:check && npm run admin-framework:check && npm run build"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "bootstrap": "^5.3.8",
    "next": "^16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.1.0",
    "svix": "^1.96.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.12"
  }
}
